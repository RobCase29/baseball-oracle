{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baseball-oracle.vercel.app/schemas/community-signals.v1.schema.json",
  "title": "Baseball Oracle Community Signals v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contractVersion", "snapshot", "items", "meta"],
  "properties": {
    "schemaVersion": { "const": "community-signals.v1" },
    "contractVersion": { "const": "community-signals-contract/v1" },
    "snapshot": {
      "anyOf": [
        { "$ref": "#/$defs/snapshot" },
        { "type": "null" }
      ]
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    },
    "meta": { "$ref": "#/$defs/meta" }
  },
  "$defs": {
    "nullablePositiveInteger": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "nullableInteger": {
      "type": ["integer", "null"]
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "observedAt", "sourceUpdatedAt"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^community-signals-snapshot/v1:[a-f0-9]{64}$"
        },
        "observedAt": { "type": "string", "format": "date-time" },
        "sourceUpdatedAt": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      }
    },
    "player": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oracleId", "mlbamId", "hkbId", "name"],
      "properties": {
        "oracleId": { "type": ["string", "null"] },
        "mlbamId": { "type": "string", "pattern": "^[1-9][0-9]{0,11}$" },
        "hkbId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "movement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank7d", "rank30d", "value7d", "value30d"],
      "properties": {
        "rank7d": { "$ref": "#/$defs/nullableInteger" },
        "rank30d": { "$ref": "#/$defs/nullableInteger" },
        "value7d": { "$ref": "#/$defs/nullableInteger" },
        "value30d": { "$ref": "#/$defs/nullableInteger" }
      }
    },
    "attention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["views30d", "rank30d", "prospectViews30d", "prospectRank30d"],
      "properties": {
        "views30d": { "$ref": "#/$defs/nullablePositiveInteger" },
        "rank30d": { "$ref": "#/$defs/nullablePositiveInteger" },
        "prospectViews30d": { "$ref": "#/$defs/nullablePositiveInteger" },
        "prospectRank30d": { "$ref": "#/$defs/nullablePositiveInteger" }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank30d", "value30d"],
      "properties": {
        "rank30d": {
          "anyOf": [
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 31,
              "items": {
                "anyOf": [
                  { "type": "integer", "minimum": 1 },
                  { "type": "null" }
                ]
              }
            },
            { "type": "null" }
          ]
        },
        "value30d": {
          "anyOf": [
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 31,
              "items": {
                "anyOf": [
                  { "type": "integer", "minimum": 10, "maximum": 10000 },
                  { "type": "null" }
                ]
              }
            },
            { "type": "null" }
          ]
        }
      }
    },
    "dynastyScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "value",
        "signalStatus",
        "overallRank",
        "overallUniverse",
        "prospectRank",
        "prospectUniverse",
        "movement",
        "attention",
        "history"
      ],
      "properties": {
        "label": { "const": "Dynasty Score" },
        "value": { "type": "integer", "minimum": 10, "maximum": 10000 },
        "signalStatus": { "enum": ["ranked", "default_floor"] },
        "overallRank": { "$ref": "#/$defs/nullablePositiveInteger" },
        "overallUniverse": { "$ref": "#/$defs/nullablePositiveInteger" },
        "prospectRank": { "$ref": "#/$defs/nullablePositiveInteger" },
        "prospectUniverse": { "$ref": "#/$defs/nullablePositiveInteger" },
        "movement": { "$ref": "#/$defs/movement" },
        "attention": { "$ref": "#/$defs/attention" },
        "history": { "$ref": "#/$defs/history" }
      },
      "allOf": [
        {
          "if": { "properties": { "signalStatus": { "const": "default_floor" } } },
          "then": { "properties": { "value": { "const": 10 } } },
          "else": { "properties": { "value": { "exclusiveMinimum": 10 } } }
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "capturedAt", "updatedAt"],
      "properties": {
        "name": { "const": "HarryKnowsBall" },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://(www\\.)?harryknowsball\\.com/"
        },
        "capturedAt": { "type": "string", "format": "date-time" },
        "updatedAt": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordVersion", "player", "dynastyScore", "source"],
      "properties": {
        "recordVersion": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "player": { "$ref": "#/$defs/player" },
        "dynastyScore": { "$ref": "#/$defs/dynastyScore" },
        "source": { "$ref": "#/$defs/source" }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "excludedFromOracleModel",
        "nullMeans",
        "nullMeansUnavailableNotZero",
        "identityPolicy",
        "signalType",
        "dynastyScoreScale",
        "requestedIds",
        "unmatchedIds"
      ],
      "properties": {
        "excludedFromOracleModel": { "const": true },
        "nullMeans": { "const": "unavailable_not_zero" },
        "nullMeansUnavailableNotZero": { "const": true },
        "identityPolicy": { "const": "exact_mlbam_join_no_name_matching" },
        "signalType": { "const": "crowdsourced_dynasty_sentiment" },
        "dynastyScoreScale": {
          "type": "object",
          "additionalProperties": false,
          "required": ["minimum", "maximum", "unit", "isProbability"],
          "properties": {
            "minimum": { "const": 10 },
            "maximum": { "const": 10000 },
            "unit": { "const": "HarryKnowsBall dynasty value" },
            "isProbability": { "const": false }
          }
        },
        "requestedIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "unmatchedIds": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
