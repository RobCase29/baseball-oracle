{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baseball-oracle.vercel.app/schemas/player-map-feed.v4.schema.json",
  "title": "Baseball Oracle Player Map Feed v4",
  "description": "Compact, market-independent player intelligence response returned by GET /api/players?view=map. Career Index is a fixed career-value index; stage standing is a route-specific ordinal and Oracle Score is deprecated.",
  "type": "object",
  "required": ["schemaVersion", "items", "page", "meta"],
  "properties": {
    "schemaVersion": {
      "const": "player-map-feed.v4"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feedItem"
      }
    },
    "page": {
      "$ref": "#/$defs/page"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nullableDateTime": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "nullablePositiveInteger": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "nullableNumber": {
      "type": ["number", "null"]
    },
    "route": {
      "enum": ["milb", "rookie", "mlb"]
    },
    "feedItem": {
      "type": "object",
      "required": ["playerId", "identity", "externalIds", "context", "currentEvidence", "assessment"],
      "properties": {
        "playerId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "identity": {
          "$ref": "#/$defs/playerIdentity"
        },
        "externalIds": {
          "$ref": "#/$defs/externalIds"
        },
        "context": {
          "$ref": "#/$defs/playerContext"
        },
        "currentEvidence": {
          "$ref": "#/$defs/currentEvidence"
        },
        "assessment": {
          "$ref": "#/$defs/assessment"
        }
      },
      "additionalProperties": false
    },
    "playerIdentity": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "externalIds": {
      "description": "Exact provider identifiers. Values are serialized as strings; null means that provider identifier is unavailable.",
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": ["string", "null"]
      }
    },
    "playerContext": {
      "type": "object",
      "required": [
        "playerType",
        "stage",
        "age",
        "level",
        "organization",
        "organizationCode",
        "position"
      ],
      "properties": {
        "playerType": {
          "enum": ["Hitter", "Pitcher", "Two-way"]
        },
        "stage": {
          "enum": ["pre_debut", "post_debut_minors", "recent_callup", "early_mlb", "established_mlb", "inactive"]
        },
        "age": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "level": {
          "$ref": "#/$defs/nullableString"
        },
        "organization": {
          "$ref": "#/$defs/nullableString"
        },
        "organizationCode": {
          "$ref": "#/$defs/nullableString"
        },
        "position": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "additionalProperties": false
    },
    "currentEvidence": {
      "description": "Current source evidence kept separate from the career model and market inputs.",
      "type": "object",
      "required": ["minorStats", "prospectScouting"],
      "properties": {
        "minorStats": {
          "anyOf": [
            { "$ref": "#/$defs/currentMinorStats" },
            { "type": "null" }
          ]
        },
        "prospectScouting": {
          "anyOf": [
            { "$ref": "#/$defs/currentProspectScouting" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "playerOpportunity": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "currentMinorStats": {
      "type": "object",
      "required": [
        "source", "season", "asOf", "currentLevel", "highestObservedLevel",
        "levelsObserved", "opportunity", "hitting", "pitching"
      ],
      "properties": {
        "source": { "const": "MLB StatsAPI" },
        "season": { "type": "integer", "minimum": 1871, "maximum": 2200 },
        "asOf": { "$ref": "#/$defs/nullableDateTime" },
        "currentLevel": { "$ref": "#/$defs/nullableString" },
        "highestObservedLevel": { "$ref": "#/$defs/nullableString" },
        "levelsObserved": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "opportunity": { "$ref": "#/$defs/playerOpportunity" },
        "hitting": {
          "anyOf": [
            { "$ref": "#/$defs/currentMinorHitting" },
            { "type": "null" }
          ]
        },
        "pitching": {
          "anyOf": [
            { "$ref": "#/$defs/currentMinorPitching" },
            { "type": "null" }
          ]
        }
      },
      "oneOf": [
        {
          "properties": {
            "hitting": { "$ref": "#/$defs/currentMinorHitting" },
            "pitching": { "type": "null" }
          }
        },
        {
          "properties": {
            "hitting": { "type": "null" },
            "pitching": { "$ref": "#/$defs/currentMinorPitching" }
          }
        }
      ],
      "additionalProperties": false
    },
    "currentMinorHitting": {
      "type": "object",
      "required": [
        "pa", "ba", "obp", "slg", "ops", "homeRuns", "walks",
        "strikeouts", "stolenBases"
      ],
      "properties": {
        "pa": { "type": "integer", "minimum": 0 },
        "ba": { "$ref": "#/$defs/nullableNumber" },
        "obp": { "$ref": "#/$defs/nullableNumber" },
        "slg": { "$ref": "#/$defs/nullableNumber" },
        "ops": { "$ref": "#/$defs/nullableNumber" },
        "homeRuns": { "$ref": "#/$defs/nullableNumber" },
        "walks": { "$ref": "#/$defs/nullableNumber" },
        "strikeouts": { "$ref": "#/$defs/nullableNumber" },
        "stolenBases": { "$ref": "#/$defs/nullableNumber" }
      },
      "additionalProperties": false
    },
    "currentMinorPitching": {
      "type": "object",
      "required": [
        "ip", "era", "whip", "strikeoutRate", "walkRate", "kMinusBbRate",
        "strikeouts", "walksAllowed"
      ],
      "properties": {
        "ip": { "type": "number", "minimum": 0 },
        "era": { "$ref": "#/$defs/nullableNumber" },
        "whip": { "$ref": "#/$defs/nullableNumber" },
        "strikeoutRate": { "$ref": "#/$defs/nullableNumber" },
        "walkRate": { "$ref": "#/$defs/nullableNumber" },
        "kMinusBbRate": { "$ref": "#/$defs/nullableNumber" },
        "strikeouts": { "$ref": "#/$defs/nullableNumber" },
        "walksAllowed": { "$ref": "#/$defs/nullableNumber" }
      },
      "additionalProperties": false
    },
    "currentProspectScouting": {
      "type": "object",
      "required": [
        "source", "reportSeason", "asOf", "organizationRank", "overallRank",
        "futureValue", "futureValueRaw", "eta", "grades"
      ],
      "properties": {
        "source": { "const": "FanGraphs" },
        "reportSeason": { "type": "integer", "minimum": 1900, "maximum": 2200 },
        "asOf": { "$ref": "#/$defs/nullableDateTime" },
        "organizationRank": { "$ref": "#/$defs/nullablePositiveInteger" },
        "overallRank": { "$ref": "#/$defs/nullablePositiveInteger" },
        "futureValue": { "$ref": "#/$defs/nullableString" },
        "futureValueRaw": { "$ref": "#/$defs/nullableString" },
        "eta": { "type": ["integer", "null"], "minimum": 1900, "maximum": 2200 },
        "grades": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "label", "present", "future"],
            "properties": {
              "key": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "present": { "type": ["number", "null"] },
              "future": { "type": ["number", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "assessment": {
      "description": "The ranking-critical fields are closed below. Additional explanatory score, trait, signal, and evidence fields remain forward-compatible within v4.",
      "type": "object",
      "required": [
        "version",
        "asOf",
        "route",
        "mappingStatus",
        "claimStatus",
        "state",
        "careerIndex",
        "stageStanding",
        "oracleScore",
        "marketIndependent",
        "marketInputsIncluded",
        "careerIndexComparableAcrossRoutes",
        "stageStandingComparableWithinStageOnly"
      ],
      "properties": {
        "version": {
          "const": "oracle-player-map/v3"
        },
        "asOf": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "route": {
          "$ref": "#/$defs/route"
        },
        "mappingStatus": {
          "enum": ["scored", "insufficient_sample", "coverage_gap", "withheld", "not_applicable"]
        },
        "claimStatus": {
          "enum": ["research_only", "descriptive_only", "withheld"]
        },
        "state": {
          "enum": ["conviction", "discovery", "rising", "monitor", "mapped", "evidence_building", "profile_only"]
        },
        "careerIndex": {
          "$ref": "#/$defs/careerIndex"
        },
        "stageStanding": {
          "$ref": "#/$defs/stageStanding"
        },
        "handling": {
          "$ref": "#/$defs/playerHandling"
        },
        "oracleScore": {
          "$ref": "#/$defs/deprecatedOracleScore"
        },
        "marketIndependent": {
          "const": true
        },
        "marketInputsIncluded": {
          "const": false
        },
        "careerIndexComparableAcrossRoutes": {
          "const": true
        },
        "stageStandingComparableWithinStageOnly": {
          "const": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "route": {
                "const": "milb"
              }
            },
            "required": ["route"]
          },
          "then": {
            "properties": {
              "careerIndex": {
                "properties": {
                  "route": {
                    "const": "milb"
                  }
                }
              },
              "oracleScore": {
                "properties": {
                  "route": {
                    "const": "milb"
                  }
                }
              },
              "stageStanding": {
                "properties": {
                  "metric": {
                    "const": "prospect_career_outcome_rank"
                  },
                  "method": {
                    "const": "frozen_model_artifact_rank"
                  },
                  "cohort": {
                    "const": "prospect_forecast"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "route": {
                "const": "rookie"
              }
            },
            "required": ["route"]
          },
          "then": {
            "properties": {
              "careerIndex": {
                "properties": {
                  "route": {
                    "const": "rookie"
                  }
                }
              },
              "oracleScore": {
                "properties": {
                  "route": {
                    "const": "rookie"
                  }
                }
              },
              "stageStanding": {
                "properties": {
                  "metric": {
                    "const": "prospect_career_outcome_rank"
                  },
                  "method": {
                    "const": "frozen_model_artifact_rank"
                  },
                  "cohort": {
                    "const": "frozen_prospect_prior"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "route": {
                "const": "mlb"
              }
            },
            "required": ["route"]
          },
          "then": {
            "properties": {
              "careerIndex": {
                "properties": {
                  "route": {
                    "const": "mlb"
                  }
                }
              },
              "oracleScore": {
                "properties": {
                  "route": {
                    "const": "mlb"
                  }
                }
              },
              "stageStanding": {
                "properties": {
                  "metric": {
                    "const": "mlb_hof_caliber_rank"
                  },
                  "method": {
                    "const": "current_census_probability_rank"
                  },
                  "cohort": {
                    "const": "current_mlb"
                  }
                }
              }
            }
          }
        }
      ],
      "additionalProperties": true
    },
    "playerHandling": {
      "description": "Versioned treatment for unusual role, lifecycle, freshness, identity, or model-coverage cases. A special status explains why a score is pending or withheld without substituting observed value for a forecast.",
      "type": "object",
      "required": ["version", "status", "primary", "notes", "unclassifiedWithheld"],
      "properties": {
        "version": {
          "const": "player-handling/v1"
        },
        "status": {
          "enum": ["standard", "special"]
        },
        "primary": {
          "oneOf": [
            { "$ref": "#/$defs/playerHandlingNote" },
            { "type": "null" }
          ]
        },
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/playerHandlingNote" }
        },
        "unclassifiedWithheld": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "playerHandlingNote": {
      "type": "object",
      "required": ["code", "category", "label", "summary", "handling", "scoreTreatment"],
      "properties": {
        "code": {
          "enum": [
            "two_way_model_scope",
            "role_transition_model_scope",
            "hall_standard_model_scope",
            "debut_age_model_scope",
            "post_debut_minor_assignment",
            "rookie_model_pending",
            "rookie_prior_unmatched",
            "young_elite_model_scope",
            "stale_return_features",
            "current_opportunity_missing",
            "identity_link_missing",
            "forecast_not_available",
            "forecast_withheld_other"
          ]
        },
        "category": {
          "enum": ["model_scope", "career_transition", "data_freshness", "identity", "coverage"]
        },
        "label": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "handling": { "type": "string", "minLength": 1 },
        "scoreTreatment": {
          "enum": ["withheld", "pending", "unaffected"]
        }
      },
      "additionalProperties": false
    },
    "careerIndex": {
      "description": "Primary fixed-scale career-value magnitude. Prospect and Rookie Track values are conditional on MLB arrival; arrival confidence remains separate.",
      "type": "object",
      "required": ["version", "value", "scale", "route", "basis", "status", "asOf", "definition", "forecastLineage"],
      "properties": {
        "version": {
          "const": "career-index-war-v2"
        },
        "value": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "scale": {
          "const": "fixed_career_value_index"
        },
        "route": {
          "$ref": "#/$defs/route"
        },
        "basis": {
          "enum": ["conditional_on_mlb_arrival", "current_mlb_terminal"]
        },
        "status": {
          "enum": ["research", "withheld"]
        },
        "asOf": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "definition": {
          "const": "Fixed career-value index from final-career WAR P50, P75, and P90 mapped to versioned WAR anchors; prospect and Rookie Track values are conditional on MLB arrival, which is scored separately; not a probability, percentile, confidence score, or expected WAR"
        },
        "forecastLineage": {
          "$ref": "#/$defs/forecastLineage"
        }
      },
      "oneOf": [
        {
          "properties": {
            "value": {
              "type": "number"
            },
            "status": {
              "const": "research"
            }
          }
        },
        {
          "properties": {
            "value": {
              "type": "null"
            },
            "status": {
              "const": "withheld"
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "forecastLineage": {
      "type": "object",
      "required": ["modelVersion", "targetVersion", "dataVersion", "providerVersion"],
      "properties": {
        "modelVersion": {
          "$ref": "#/$defs/nullableString"
        },
        "targetVersion": {
          "$ref": "#/$defs/nullableString"
        },
        "dataVersion": {
          "$ref": "#/$defs/nullableString"
        },
        "providerVersion": {
          "$ref": "#/$defs/nullableString"
        }
      },
      "additionalProperties": false
    },
    "stageStanding": {
      "description": "Relative rank inside the declared route-specific model cohort. Lower rank and topPercent are better; filters never renumber this standing.",
      "type": "object",
      "required": [
        "version",
        "metric",
        "method",
        "direction",
        "scope",
        "isFilteredResultOrdinal",
        "target",
        "rank",
        "universe",
        "topPercent",
        "tailBand",
        "cohort",
        "asOf"
      ],
      "properties": {
        "version": {
          "const": "stage-standing-v1"
        },
        "metric": {
          "enum": ["prospect_career_outcome_rank", "mlb_hof_caliber_rank"]
        },
        "method": {
          "enum": ["frozen_model_artifact_rank", "current_census_probability_rank"]
        },
        "direction": {
          "const": "lower_is_better"
        },
        "scope": {
          "const": "declared_model_cohort"
        },
        "isFilteredResultOrdinal": {
          "const": false
        },
        "target": {
          "$ref": "#/$defs/nullableString"
        },
        "rank": {
          "$ref": "#/$defs/nullablePositiveInteger"
        },
        "universe": {
          "$ref": "#/$defs/nullablePositiveInteger"
        },
        "topPercent": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "tailBand": {
          "type": ["string", "null"],
          "enum": ["Top 0.1%", "Top 1%", "Top 5%", "Top 10%", "Top 25%", "Outside top 25%", null]
        },
        "cohort": {
          "enum": ["prospect_forecast", "frozen_prospect_prior", "current_mlb"]
        },
        "asOf": {
          "$ref": "#/$defs/nullableDateTime"
        }
      },
      "oneOf": [
        {
          "properties": {
            "rank": {
              "type": "integer",
              "minimum": 1
            },
            "universe": {
              "type": "integer",
              "minimum": 1
            },
            "topPercent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "tailBand": {
              "type": "string"
            }
          }
        },
        {
          "properties": {
            "rank": {
              "type": "null"
            },
            "universe": {
              "type": "null"
            },
            "topPercent": {
              "type": "null"
            },
            "tailBand": {
              "type": "null"
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "deprecatedOracleScore": {
      "description": "Deprecated v1 stage-percentile compatibility field. New consumers must use careerIndex and stageStanding.",
      "type": "object",
      "required": [
        "deprecated",
        "replacement",
        "value",
        "scale",
        "route",
        "rank",
        "universe",
        "target",
        "asOf",
        "definition"
      ],
      "properties": {
        "deprecated": {
          "const": true
        },
        "replacement": {
          "const": "careerIndex"
        },
        "value": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "scale": {
          "const": "stage_rank_percentile"
        },
        "route": {
          "$ref": "#/$defs/route"
        },
        "rank": {
          "$ref": "#/$defs/nullablePositiveInteger"
        },
        "universe": {
          "$ref": "#/$defs/nullablePositiveInteger"
        },
        "target": {
          "$ref": "#/$defs/nullableString"
        },
        "asOf": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "definition": {
          "const": "Rounded stage-specific modeled outcome rank percentile; not a probability or composite score"
        }
      },
      "additionalProperties": false
    },
    "page": {
      "type": "object",
      "required": ["page", "limit", "total", "totalPages"],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "totalPages": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "required": [
        "source",
        "dataAsOf",
        "season",
        "coverage",
        "forecastStatus",
        "playerMapVersion",
        "playerMapCoverage",
        "matchingPlayerCount",
        "matchingMappedCount",
        "snapshotId",
        "snapshotScope",
        "marketIndependent",
        "marketInputsIncluded",
        "primaryScoreSemantics",
        "scoreSemantics",
        "legacyScoreSemantics",
        "scoreSemanticsDeprecated",
        "rankingContract",
        "ordering"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "dataAsOf": {
          "$ref": "#/$defs/nullableDateTime"
        },
        "season": {
          "type": ["integer", "null"],
          "minimum": 1876,
          "maximum": 2200
        },
        "coverage": {
          "type": "string",
          "minLength": 1
        },
        "forecastStatus": {
          "enum": ["not_published", "research_only", "published"]
        },
        "playerMapVersion": {
          "const": "oracle-player-map/v3"
        },
        "playerMapCoverage": {
          "type": "integer",
          "minimum": 0
        },
        "matchingPlayerCount": {
          "type": "integer",
          "minimum": 0
        },
        "matchingMappedCount": {
          "description": "Number of matching records with a non-null assessment.careerIndex.value.",
          "type": "integer",
          "minimum": 0
        },
        "snapshotId": {
          "type": "string",
          "pattern": "^oracle-ranking-snapshot/v1:[a-f0-9]{64}$"
        },
        "snapshotScope": {
          "const": "ranking_and_census"
        },
        "marketIndependent": {
          "const": true
        },
        "marketInputsIncluded": {
          "const": false
        },
        "primaryScoreSemantics": {
          "const": "fixed_career_value_index"
        },
        "scoreSemantics": {
          "const": "stage_specific_ordinal_not_market_value"
        },
        "legacyScoreSemantics": {
          "const": "stage_specific_ordinal_not_market_value"
        },
        "scoreSemanticsDeprecated": {
          "const": true
        },
        "rankingContract": {
          "$ref": "#/$defs/rankingContract"
        },
        "ordering": {
          "$ref": "#/$defs/ordering"
        },
        "identity": {
          "$ref": "#/$defs/identityResolution"
        }
      },
      "additionalProperties": true
    },
    "rankingContract": {
      "type": "object",
      "required": [
        "version",
        "primaryMetric",
        "primarySort",
        "primaryComparableAcrossRoutes",
        "stageStandingMetric",
        "stageStandingComparableWithinStageOnly",
        "stageStandingIsFilteredResultOrdinal",
        "legacyMetric",
        "legacyDeprecated"
      ],
      "properties": {
        "version": {
          "const": "player-ranking-contract/v1"
        },
        "primaryMetric": {
          "const": "careerIndex"
        },
        "primarySort": {
          "const": "careerIndex"
        },
        "primaryComparableAcrossRoutes": {
          "const": true
        },
        "stageStandingMetric": {
          "const": "stageStanding"
        },
        "stageStandingComparableWithinStageOnly": {
          "const": true
        },
        "stageStandingIsFilteredResultOrdinal": {
          "const": false
        },
        "legacyMetric": {
          "const": "oracleScore"
        },
        "legacyDeprecated": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "ordering": {
      "type": "object",
      "required": ["requestedSort", "appliedSort", "legacyAliasUsed", "metric", "field", "fieldExposed", "direction", "scope", "nulls", "tieBreakers"],
      "properties": {
        "requestedSort": {
          "enum": ["careerIndex", "stageStanding", "alphaOpportunity", "hofProbability", "nearTermImpact", "finalWar", "arrival36", "age", "name"]
        },
        "appliedSort": {
          "enum": ["careerIndex", "stageStanding", "hofProbability", "nearTermImpact", "finalWar", "arrival36", "age", "name"]
        },
        "legacyAliasUsed": {
          "description": "True only when requestedSort=alphaOpportunity was normalized to appliedSort=stageStanding.",
          "type": "boolean"
        },
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "fieldExposed": {
          "type": "boolean"
        },
        "direction": {
          "enum": ["ascending", "descending"]
        },
        "scope": {
          "enum": ["directory", "cross_stage", "stage"]
        },
        "nulls": {
          "const": "last"
        },
        "tieBreakers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/orderingMetric"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "fieldExposed": { "const": true } },
            "required": ["fieldExposed"]
          },
          "then": {
            "properties": { "field": { "type": "string" } }
          },
          "else": {
            "properties": { "field": { "type": "null" } }
          }
        },
        {
          "if": {
            "properties": { "requestedSort": { "const": "alphaOpportunity" } },
            "required": ["requestedSort"]
          },
          "then": {
            "properties": {
              "appliedSort": { "const": "stageStanding" },
              "legacyAliasUsed": { "const": true }
            }
          },
          "else": {
            "properties": { "legacyAliasUsed": { "const": false } }
          }
        },
        {
          "if": {
            "properties": { "scope": { "const": "cross_stage" } },
            "required": ["scope"]
          },
          "then": {
            "properties": { "appliedSort": { "const": "careerIndex" } }
          }
        },
        {
          "if": {
            "properties": { "scope": { "const": "directory" } },
            "required": ["scope"]
          },
          "then": {
            "properties": { "appliedSort": { "enum": ["name", "age"] } }
          }
        }
      ],
      "additionalProperties": false
    },
    "orderingMetric": {
      "type": "object",
      "required": ["metric", "field", "fieldExposed", "direction"],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "fieldExposed": {
          "type": "boolean"
        },
        "direction": {
          "enum": ["ascending", "descending"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "fieldExposed": { "const": true } },
            "required": ["fieldExposed"]
          },
          "then": {
            "properties": { "field": { "type": "string" } }
          },
          "else": {
            "properties": { "field": { "type": "null" } }
          }
        }
      ],
      "additionalProperties": false
    },
    "identityResolution": {
      "description": "Optional census-level identity and deduplication diagnostics present on non-degraded responses.",
      "type": "object",
      "required": [
        "minorRoleRows",
        "canonicalMinorPlayers",
        "duplicateMinorRoleRowsRemoved",
        "minorTwoWayPlayers",
        "crossStageDuplicatesRemoved",
        "minorPlayersMissingMlbam",
        "mlbPlayersMissingMlbam",
        "currentMlbProfilesOutsideModelCensus",
        "experiencedMinorRowsExcludedFromRankings",
        "currentSeasonDebutMinorRowsIdentified",
        "minorIdsRecoveredFromExactCrosswalk",
        "identityPolicy",
        "identityCrosswalkAsOf",
        "identityCrosswalkRecords",
        "identityCrosswalkStatus",
        "identityCrosswalkAgeHours",
        "identityCrosswalkMaxAgeHours",
        "identityOverlayRecords",
        "identityOverlayConflicts",
        "identityOverlayNewestObservedAt",
        "currentMlbRows",
        "unmatchedCurrentBbrefIds",
        "conflictingCurrentMlbIds"
      ],
      "properties": {
        "minorRoleRows": {
          "type": "integer",
          "minimum": 0
        },
        "canonicalMinorPlayers": {
          "type": "integer",
          "minimum": 0
        },
        "duplicateMinorRoleRowsRemoved": {
          "type": "integer",
          "minimum": 0
        },
        "minorTwoWayPlayers": {
          "type": "integer",
          "minimum": 0
        },
        "crossStageDuplicatesRemoved": {
          "type": "integer",
          "minimum": 0
        },
        "minorPlayersMissingMlbam": {
          "type": "integer",
          "minimum": 0
        },
        "mlbPlayersMissingMlbam": {
          "type": "integer",
          "minimum": 0
        },
        "currentMlbProfilesOutsideModelCensus": {
          "type": "integer",
          "minimum": 0
        },
        "experiencedMinorRowsExcludedFromRankings": {
          "type": "integer",
          "minimum": 0
        },
        "currentSeasonDebutMinorRowsIdentified": {
          "type": "integer",
          "minimum": 0
        },
        "minorIdsRecoveredFromExactCrosswalk": {
          "type": "integer",
          "minimum": 0
        },
        "identityPolicy": {
          "const": "exact_mlbam_bbref_plus_durable_chadwick_overlay_no_name_matching"
        },
        "identityCrosswalkAsOf": {
          "type": "string",
          "format": "date-time"
        },
        "identityCrosswalkRecords": {
          "type": "integer",
          "minimum": 1
        },
        "identityCrosswalkStatus": {
          "enum": ["current", "stale", "invalid"]
        },
        "identityCrosswalkAgeHours": {
          "type": ["number", "null"]
        },
        "identityCrosswalkMaxAgeHours": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "identityOverlayRecords": {
          "type": "integer",
          "minimum": 0
        },
        "identityOverlayConflicts": {
          "type": "integer",
          "minimum": 0
        },
        "identityOverlayNewestObservedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "currentMlbRows": {
          "type": "integer",
          "minimum": 0
        },
        "unmatchedCurrentBbrefIds": {
          "type": "integer",
          "minimum": 0
        },
        "conflictingCurrentMlbIds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
