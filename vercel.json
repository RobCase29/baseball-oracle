{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run db:deploy && npm run bootstrap:mlb-rosters:remote && npm run archive:register-catalog:remote && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/football",
      "destination": "/football/index.html"
    }
  ],
  "functions": {
    "api/admin/*.ts": {
      "maxDuration": 300
    },
    "api/cron/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-current",
      "schedule": "17 10,22 * * *"
    }
  ]
}
