# Server-only database connections. Never prefix these with VITE_.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Protects server-side ingestion endpoints. Generate a long random value.
INGESTION_SECRET=

# Protects Vercel Cron invocations. Use a different random value from INGESTION_SECRET.
CRON_SECRET=

# Server-only private Vercel Blob archive credential. Never prefix with VITE_.
BLOB_READ_WRITE_TOKEN=

# Optional override. The connector otherwise uses the documented research snapshot URL.
FANGRAPHS_PROSPECTS_URL=

# Required before the scheduled job will collect the current FanGraphs board.
# This is deliberately separate from the historical snapshot override above.
FANGRAPHS_CURRENT_PROSPECTS_URL=

# Optional server-side override for the authorized Prospect Savant API origin.
PROSPECT_SAVANT_API_BASE=

# Server-only credential for the private card-market valuation feed.
# Never expose this through a VITE_ variable or client-side request.
BACKSTOP_API_KEY=

# Optional server-side override for the card-market API origin.
BACKSTOP_API_BASE=https://backstopcards.com

# Private research workspace sign-in. Both values are server-only.
ORACLE_ACCESS_CODE=
ORACLE_SESSION_SECRET=

# Server-to-server read access for the player and dynasty APIs.
ORACLE_API_KEY=
