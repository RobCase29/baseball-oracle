{
  "name": "baseball-oracle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "npx vercel dev",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node --env-file=.env.local --import tsx scripts/migrate.ts",
    "db:seed:sources": "node --env-file=.env.local --import tsx scripts/seed-sources.ts",
    "db:setup": "npm run db:migrate && npm run db:seed:sources",
    "db:migrate:remote": "tsx scripts/migrate.ts",
    "db:seed:sources:remote": "tsx scripts/seed-sources.ts",
    "db:deploy": "npm run db:migrate:remote && npm run db:seed:sources:remote",
    "ingest:fangraphs": "node --env-file=.env.local --import tsx scripts/ingest/fangraphs-prospects.ts",
    "ingest:prospect-savant": "node --env-file=.env.local --import tsx scripts/ingest/prospect-savant-leaders.ts",
    "data:acquire": "tsx scripts/data/acquire-model-data.ts",
    "audit:twtc": ".venv/bin/python scripts/audits/audit_trouble_with_curve.py",
    "archive:locked-corpus": "node --env-file=.env.local --import tsx scripts/archive/archive-locked-corpus.ts",
    "archive:sports-reference": "node --env-file=.env.local --import tsx scripts/archive/archive-sports-reference-season.ts",
    "archive:register-catalog": "node --env-file=.env.local --import tsx scripts/archive/register-archive-catalog.ts",
    "archive:register-catalog:remote": "tsx scripts/archive/register-archive-catalog.ts",
    "backfill:sports-reference": "tsx scripts/backfill/sports-reference-register.ts",
    "backfill:sports-reference:test": "vitest run scripts/backfill/sports-reference-register.test.ts",
    "model:setup": "python3 modeling/bootstrap.py",
    "model:prepare": ".venv/bin/python modeling/prepare_dataset.py",
    "model:train": ".venv/bin/python modeling/train_arrival_baseline.py",
    "model:population:prepare": ".venv/bin/python modeling/arrival_corpus.py --discover-locked-seasons --max-season=2019",
    "model:population:train": ".venv/bin/python modeling/train_arrival_population.py",
    "model:population:audit": ".venv/bin/python modeling/arrival_sufficiency.py",
    "model:population:calibrate": ".venv/bin/python modeling/train_arrival_calibration.py",
    "model:population:all": "npm run model:population:prepare && npm run model:population:train",
    "model:evaluation:lock": ".venv/bin/python modeling/arrival_holdout.py --metrics artifacts/arrival-population-v1/metrics.json --protocol modeling/config/arrival-validation-v2.json --calibration-manifest artifacts/arrival-calibration-v1/calibration_manifest.json --sufficiency-report artifacts/arrival-sufficiency-v1/report.json --output data/model-locks/arrival-post-pandemic-v1.json",
    "model:evaluation:prepare": ".venv/bin/python modeling/arrival_corpus.py --dataset-manifest data/processed/model-v1-bref-2021/dataset_manifest.json --dataset-manifest data/processed/model-v1-bref-2022/dataset_manifest.json --dataset-manifest data/processed/model-v1-bref-2023/dataset_manifest.json --dataset-manifest data/processed/model-v1-bref-2024/dataset_manifest.json --dataset-manifest data/processed/model-v1-bref-2025/dataset_manifest.json --output-dir data/processed/arrival-external-v1",
    "model:evaluation:predict": ".venv/bin/python -m modeling.arrival_external predict --lock data/model-locks/arrival-post-pandemic-v1.json --external-corpus-manifest data/processed/arrival-external-v1/corpus_manifest.json --artifact-dir artifacts/arrival-external-v1",
    "model:evaluation:score": ".venv/bin/python -m modeling.arrival_external evaluate --lock data/model-locks/arrival-post-pandemic-v1.json --external-corpus-manifest data/processed/arrival-external-v1/corpus_manifest.json --prediction-manifest artifacts/arrival-external-v1/prediction_manifest.json --artifact-dir artifacts/arrival-external-v1",
    "model:test": ".venv/bin/python -m pytest modeling",
    "model:all": "npm run model:test && npm run model:prepare && npm run model:train"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^27.0.1",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^3.2.7"
  }
}
